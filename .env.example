# ----------------------------------------------------------------------------
# Vyra environment configuration
# Copy this file to `.env` and fill in your own keys. NEVER commit the real .env.
# ----------------------------------------------------------------------------

# --- Google Gemini (AI engine) -------------------------------------------------
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model to use. Must be a CURRENT model — gemini-1.5-flash and gemini-2.0-flash
# have been retired by Google. Free-tier options: gemini-2.5-flash (recommended),
# gemini-2.5-flash-lite. See https://ai.google.dev/gemini-api/docs/models
GEMINI_MODEL=gemini-2.5-flash

# --- Weather (assistant tools) -------------------------------------------------
# Free key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# --- Firebase (optional) -------------------------------------------------------
# Vyra runs fine without Firebase. Fill these only if you enable cloud features.
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
